---
import '../styles/global.css';
import Dashboard from '../components/Dashboard.jsx';
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Panel privado y client-side para consultar los repositorios recientes de GitHub, sus últimos commits, lenguajes principales y deployments."
    />
    <title>Proyect Admin · Dashboard de repositorios GitHub</title>
  </head>
  <body class="min-h-screen bg-slate-100 text-slate-900 antialiased dark:bg-slate-950 dark:text-white">
    <main class="relative min-h-screen overflow-hidden px-4 py-8 sm:px-6 lg:px-8">
      <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top_left,rgba(56,189,248,0.24),transparent_32rem),radial-gradient(circle_at_bottom_right,rgba(99,102,241,0.2),transparent_28rem)]"></div>

      <section class="mx-auto mb-10 max-w-5xl text-center">
        <p class="mb-4 text-sm font-black uppercase tracking-[0.35em] text-sky-700 dark:text-sky-300">
          Proyect Admin
        </p>
        <h1 class="text-4xl font-black tracking-tight text-slate-950 dark:text-white sm:text-5xl lg:text-6xl">
          Dashboard client-side para tus repositorios de GitHub
        </h1>
        <p class="mx-auto mt-5 max-w-3xl text-lg leading-8 text-slate-600 dark:text-slate-300">
          Visualiza tus últimos 20 repositorios actualizados, el último commit, el lenguaje principal y el estado del deployment más reciente usando solo la API pública de GitHub desde el navegador.
        </p>
      </section>

      <div class="mx-auto max-w-7xl">
        <Dashboard client:load />
      </div>
    </main>
  </body>
</html>
